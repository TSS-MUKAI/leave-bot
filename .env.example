# Mattermost endpoints
MATTERMOST_URL=http://mattermost:8065
MATTERMOST_URL_EXTERNAL=http://localhost:8065

# Bot access token (issued from Mattermost: Integrations -> Bot Accounts)
MATTERMOST_BOT_TOKEN=replace_me

# Database connection (uses the existing postgres container on docker_default network)
DATABASE_URL=postgresql+psycopg://leavebot:leavebot@postgres:5432/leavebot

# Comma-separated verification tokens from each registered Slash Command.
# Register two commands (/leave and /有給申請) pointing to http://leave-bot:8080/slash/leave
# and paste both tokens here separated by commas.
LEAVE_BOT_SLASH_TOKENS=

LOG_LEVEL=info
TZ=Asia/Tokyo

# Admin Web UI Basic auth.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
